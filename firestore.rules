// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - photoURL: string
//   - preferences: map
//   - createdAt: timestamp
//
// Collection: projects
// Fields:
//   - id: string
//   - userId: string (required)
//   - name: string (required)
//   - roomType: string
//   - style: string
//   - originalImageUrl: string
//   - generatedImageUrl: string
//   - layout: map
//   - furniture: list
//   - createdAt: timestamp
//   - updatedAt: timestamp
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isProjectOwner(projectData) {
      return isAuthenticated() && request.auth.uid == projectData.userId;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email']) &&
        request.resource.data.uid == request.auth.uid;
    }

    // Project Rules
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Catalog Rules (Publicly readable, admin writable)
    match /catalog/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "guruking2020@gmail.com");
    }
  }
}
